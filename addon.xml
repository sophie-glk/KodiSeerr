<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.seerr4kodi" name="Seerr4Kodi" version="1.0" provider-name="soph-glk">
    <requires>
        <import addon="xbmc.python" version="3.0.1"/>
        <import addon="script.module.requests" version="2.9.1"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.service" library="service.py" startonstartup="true"/>
    <extension point="xbmc.addon.metadata">
        <summary lang="en">Seerr4Kodi - Seerr Integration</summary>
        <description lang="en">Seerr integration for Kodi. Browse, search, and request movies and TV shows. Includes Trakt support.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>